rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ════════════════════════════════════════════════════════════════════════
    // POLÍTICA GERAL
    // ────────────────────────────────────────────────────────────────────────
    // • READS continuam abertos (alunos navegam sem login).
    // • WRITES de coleções coord/prof agora exigem `request.auth.uid != null`
    //   (Firebase Auth — Google ou Email/Password).
    // • WRITES anônimos de aluno são permitidos APENAS nos fluxos públicos:
    //   solicitacoesExtra (create), trocasDiretas, checklists/respostas,
    //   clinicas/alunos (swap), provas/.../contestacoes.
    // • DELETES sensíveis continuam bloqueados (do console).
    // ════════════════════════════════════════════════════════════════════════
    function isAuth() { return request.auth != null && request.auth.uid != null; }
    // ADMIN gate: usuário precisa estar cadastrado em adminUids/{uid}.
    // O doc é criado manualmente via Firebase Console pra primeiro admin, e via
    // UI da aba Usuários pros demais. Usado pra trancar PII em coleções sensíveis.
    function isAdmin() { return isAuth() && exists(/databases/$(database)/documents/adminUids/$(request.auth.uid)); }

    // ────────────────────────────────────────────────────────────────────────
    // SIMULADOS — leitura pública. Escrita exige auth (coord/prof).
    // ────────────────────────────────────────────────────────────────────────
    match /simulados/{simId} {
      allow read: if true;
      allow create, update: if isAuth()
                            && request.resource.data.nome is string
                            && request.resource.data.nome.size() > 0
                            && request.resource.data.nome.size() < 200;
      allow delete: if false;

      match /alunos/{alunoId} {
        allow read: if true;
        // Create: exige auth (coord adiciona aluno ao simulado).
        allow create: if isAuth()
                      && request.resource.data.nome is string
                      && request.resource.data.nome.size() > 0
                      && request.resource.data.nome.size() < 200;
        // Update: coord logado OU aluno anônimo via link de email (responder presença,
        // aceitar troca direta, swap). Anônimo NÃO pode mudar nome ou matricula.
        // Usa .get(field, null) pra tolerar docs antigos sem o campo `matricula`.
        allow update: if (isAuth()
                         && request.resource.data.nome is string
                         && request.resource.data.nome.size() > 0)
                      || (request.resource.data.nome == resource.data.nome
                          && request.resource.data.get('matricula', null) == resource.data.get('matricula', null));
        allow delete: if isAuth();
      }
    }

    // ────────────────────────────────────────────────────────────────────────
    // USUÁRIOS DO PAINEL — read aberto (custom login lê pra validar senha).
    // Write exige auth (admin/coord criando outros usuários).
    // ⚠️  Senhas em plaintext: dívida técnica conhecida. Refatorar pra Cloud
    //    Function quando aposentar o custom login.
    // ────────────────────────────────────────────────────────────────────────
    match /usuarios/{username} {
      // blindado: lista de usuários (com email/senha) só legível por quem está
      // logado (Firebase Auth). Login antigo aposentado — nada lê isto pré-login.
      allow read: if isAuth();
      allow create, update: if isAuth()
                            && request.resource.data.username is string
                            && request.resource.data.senha is string
                            && request.resource.data.senha.size() < 200;
      allow delete: if false;
    }

    // ────────────────────────────────────────────────────────────────────────
    // LISTAS DE ALUNOS — leitura pública, escrita exige auth.
    // ────────────────────────────────────────────────────────────────────────
    match /listas/{listaId} {
      allow read: if true;
      allow create, update: if isAuth()
                            && request.resource.data.nome is string
                            && request.resource.data.nome.size() < 200;
      allow delete: if isAuth();
    }

    // ────────────────────────────────────────────────────────────────────────
    // SOLICITAÇÕES SIMULADO EXTRA — fluxo do aluno (create anônimo).
    // Update exige auth (coord altera status). Delete bloqueado.
    // ────────────────────────────────────────────────────────────────────────
    match /solicitacoesExtra/{reqId} {
      allow read: if true;
      allow create: if request.resource.data.nome is string
                    && request.resource.data.email is string
                    && request.resource.data.email.matches('.+@.+')
                    && request.resource.data.opcoes is list
                    && request.resource.data.opcoes.size() > 0
                    && request.resource.data.opcoes.size() <= 3;
      allow update: if isAuth()
                    && request.resource.data.nome == resource.data.nome
                    && request.resource.data.email == resource.data.email;
      allow delete: if false;
    }

    // ────────────────────────────────────────────────────────────────────────
    // TROCAS DIRETAS (entre alunos) — fluxo anônimo. Mantém aberto.
    // ────────────────────────────────────────────────────────────────────────
    match /trocasDiretas/{trocaId} {
      allow read, create, update: if true;
      allow delete: if true;
    }

    // ────────────────────────────────────────────────────────────────────────
    // ORÇAMENTO — controle de despesas por evento (admin only via UI, mas
    // tecnicamente qualquer auth pode escrever; o ADMIN_ONLY_TABS bloqueia o
    // acesso à aba no front. Read aberto pra simplicidade — sem dados sensíveis
    // de aluno aqui).
    // ────────────────────────────────────────────────────────────────────────
    match /orcamentos/{eventoId} {
      allow read: if isAuth();  // blindado: só coordenação logada
      allow create, update: if isAuth()
                            && request.resource.data.nome is string
                            && request.resource.data.nome.size() > 0
                            && request.resource.data.nome.size() < 200;
      allow delete: if false; // soft delete via status='arquivado'
    }

    // ────────────────────────────────────────────────────────────────────────
    // CONFIG — leitura aberta. Escrita exige auth.
    // ⚠️  Slack webhook em config/simExtra ainda é leitura pública.
    // ────────────────────────────────────────────────────────────────────────
    match /config/{cfgId} {
      // Leitura pública das configs que o front do aluno precisa (settings, menu,
      // simExtra, etc.). EXCETO docs sensíveis (senhasAcessos, financeiro), que
      // exigem login — protegidos por regras próprias logo abaixo.
      allow read: if cfgId != 'senhasAcessos' && cfgId != 'financeiro' && cfgId != 'poConfig';
      // Write geral: exige auth (coord/admin editando configurações).
      // Exceção: config/simExtra pode receber update anônimo SE alterar somente
      // o campo `alunosGratuitos` (incremento de quotaUsada pelo aluno gratuito
      // ao criar uma solicitação extra).
      allow create: if isAuth();
      allow update: if isAuth()
                   || (cfgId == 'simExtra'
                       && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['alunosGratuitos']));
      allow delete: if false;
    }

    // Docs SENSÍVEIS dentro de config — leitura só para usuário logado (coord/prof).
    // A escrita já é coberta pela regra wildcard acima (exige auth). Sem isto, o
    // cofre de senhas e o financeiro ficavam legíveis por qualquer um na internet.
    match /config/senhasAcessos { allow read: if isAuth(); }
    match /config/financeiro    { allow read: if isAuth(); }
    match /config/poConfig      { allow read: if isAuth(); }  // PO MEDREVIEW (interno) — schema de colunas/cursos

    // ────────────────────────────────────────────────────────────────────────
    // NOTAS — coord/prof lançam. Escrita exige auth.
    // ────────────────────────────────────────────────────────────────────────
    match /notas/{simId}/alunos/{matricula} {
      allow read: if isAuth();  // blindado: notas só coordenação logada
      allow create, update: if isAuth();
      allow delete: if false;
    }

    // ────────────────────────────────────────────────────────────────────────
    // CHECKLISTS — template (meta) editado por coord; respostas salvas por aluno.
    // ────────────────────────────────────────────────────────────────────────
    match /checklists/{simId}/meta/{docId} {
      allow read: if true;
      allow create, update: if isAuth();
      allow delete: if false;
    }
    match /checklists/{simId}/respostas/{studentId} {
      // TRAVA DE VERSÃO temporariamente DESLIGADA (2026-06-13): estava bloqueando profs
      // que não recarregaram a página, parando o trabalho. Reativar SÓ no início da próxima
      // aplicação, quando todos carregam a página do zero (código novo carimbado). A regra:
      //   allow create, update: if request.resource.data.keys().hasAll(['_ckwTs'])
      //                         && request.resource.data._ckwTs == request.time;
      // Proteção atual contra clobber = gravação cirúrgica no código novo (vale p/ quem
      // está na versão nova; abas antigas voltam a poder sobrescrever enquanto isto estiver off).
      allow read, create, update: if true;
      allow delete: if false;
    }
    // Relatório final gerado (HTML do PDF aprovado pela coord). Contém histórico
    // de notas → PROTEGIDO: só coord/prof logado lê e grava. Reaberto pelo link
    // "Baixar PDF" na grade do checklist.
    match /checklists/{simId}/relatorios/{studentId} {
      allow read, create, update: if isAuth();
      allow delete: if isAuth();
    }

    // ────────────────────────────────────────────────────────────────────────
    // DISPONIBILIDADE — prof/coord registra disponibilidade. Exige auth.
    // ────────────────────────────────────────────────────────────────────────
    match /disponibilidade/{simId}/profs/{profKey} {
      allow read: if isAuth();  // blindado: só coordenação/prof logado
      allow create, update: if isAuth();
      allow delete: if isAuth();
    }

    // ────────────────────────────────────────────────────────────────────────
    // FEEDBACK GERAL — coord/prof escreve. Exige auth.
    // ────────────────────────────────────────────────────────────────────────
    match /feedbackGeral/{simId} {
      allow read: if isAuth();  // blindado: só coordenação/prof logado
      allow create, update: if isAuth();
      allow delete: if false;
    }

    // ────────────────────────────────────────────────────────────────────────
    // FEATURES / TAREFAS (kanban interno). Exige auth.
    // ────────────────────────────────────────────────────────────────────────
    match /tarefas/{taskId} {
      allow read: if isAuth();  // blindado: kanban interno só logado
      allow create, update: if isAuth()
                            && request.resource.data.titulo is string
                            && request.resource.data.titulo.size() > 0
                            && request.resource.data.status in ['ideia','fazendo','feito']
                            && request.resource.data.prioridade in ['alta','media','baixa'];
      allow delete: if isAuth();
    }

    // ────────────────────────────────────────────────────────────────────────
    // MENTORIAS — coord cria/edita. Exige auth.
    // ────────────────────────────────────────────────────────────────────────
    match /mentorias/{mentoriaId} {
      allow read: if true;
      allow create, update: if isAuth()
                            && request.resource.data.tipo in ['TEA','TSA','TSA Oral','ME1','ME2','ME3']
                            && request.resource.data.mentorNome is string
                            && request.resource.data.mentorNome.size() > 0;
      allow delete: if isAuth();
    }

    // BLOCOS MENSAIS DE CLÍNICAS — coord cria. Exige auth.
    match /blocosClinica/{blocoId} {
      allow read: if true;
      allow create, update: if isAuth()
                            && request.resource.data.tipo in ['TEA','TSA','TSA Oral','ME1','ME2','ME3']
                            && request.resource.data.titulo is string
                            && request.resource.data.titulo.size() > 0
                            && request.resource.data.tema is string;
      allow delete: if isAuth();
    }

    // CLÍNICAS DE QUESTÕES — coord cria (parent). Subcoleção alunos: aluno responde swap (anônimo).
    match /clinicas/{clinicaId} {
      allow read: if true;
      allow create, update: if isAuth()
                            && request.resource.data.tipo in ['TEA','TSA','TSA Oral','ME1','ME2','ME3']
                            && request.resource.data.mentorNome is string
                            && request.resource.data.dataHora is string;
      allow delete: if isAuth();

      match /alunos/{alunoId} {
        allow read: if true;
        // Aluno anônimo responde swap. Coord também escreve aqui mas via fluxo logado — OK.
        allow create, update: if request.resource.data.nome is string
                              && request.resource.data.nome.size() > 0;
        allow delete: if true;
      }
    }

    // ────────────────────────────────────────────────────────────────────────
    // REVISÃO DE CASOS — coord/prof. Exige auth.
    // ────────────────────────────────────────────────────────────────────────
    match /revisaoCasos/{revId} {
      allow read: if true;
      allow create, update: if isAuth()
                            && request.resource.data.simId is string
                            && request.resource.data.status in ['rascunho','aberta','fechada','exportada'];
      allow delete: if isAuth();

      match /comentarios/{cmtId} {
        allow read: if isAuth();  // blindado: só coordenação/prof logado
        allow create, update: if isAuth()
                              && request.resource.data.profNome is string
                              && request.resource.data.profNome.size() > 0
                              && request.resource.data.targetType in ['enunciado','pergunta','item','caso'];
        allow delete: if isAuth();
      }

      match /historico/{histId} {
        allow read: if isAuth();  // blindado: só coordenação/prof logado
        allow create, update: if isAuth()
                              && request.resource.data.editadoPor is string;
        allow delete: if false;
      }
    }

    // ────────────────────────────────────────────────────────────────────────
    // GROUP REMEMBER — casos clínicos (lembranças da prova oral TSA 2ª fase).
    // Dado interno de coordenação/prof. Leitura e escrita exigem auth.
    // ────────────────────────────────────────────────────────────────────────
    match /remembers/{caseId} {
      allow read: if isAuth();  // blindado: banco interno de casos, só logado
      allow create, update: if isAuth()
                            && request.resource.data.titulo is string
                            && request.resource.data.titulo.size() > 0
                            && request.resource.data.titulo.size() < 200
                            && request.resource.data.status in ['pendente','confeccao','revisao','reprovado','aprovado','utilizado'];
      allow delete: if isAuth();

      // Versões/backup imutável — snapshot a cada gravação. Não pode ser editado
      // nem apagado (rede de segurança contra perda/sobrescrita acidental).
      match /versoes/{versaoId} {
        allow read: if isAuth();
        allow create: if isAuth();
        allow update, delete: if false;
      }
    }

    // ────────────────────────────────────────────────────────────────────────
    // RECURSOS DE PROVA — provas/questões editadas por coord (auth).
    // Contestações criadas por aluno anônimo (mantém aberto).
    // ────────────────────────────────────────────────────────────────────────
    match /provas/{provaId} {
      allow read: if true;
      // tipo: aceita qualquer string não-vazia (built-in TSA/TEA/ME1/ME2/ME3 + custom de recursosConfig.tiposCustom).
      // status: aceita schema novo (rascunho/publicada) e legado (ativa/encerrada) — front usa novo, docs antigos ainda têm legado.
      allow create, update: if isAuth()
                            && request.resource.data.nome is string
                            && request.resource.data.nome.size() > 0
                            && request.resource.data.tipo is string
                            && request.resource.data.tipo.size() > 0
                            && request.resource.data.status in ['rascunho','publicada','ativa','encerrada'];
      allow delete: if isAuth();

      match /questoes/{qId} {
        allow read: if true;
        allow create, update: if isAuth()
                              && request.resource.data.numero is number
                              && request.resource.data.modo in ['estruturado','bloco'];
        allow delete: if isAuth();

        match /contestacoes/{cId} {
          allow read: if true;
          // Aluno anônimo cria contestação
          allow create: if request.resource.data.emailAluno is string
                        && request.resource.data.emailAluno.matches('.+@.+')
                        && request.resource.data.motivo is string
                        && request.resource.data.motivo.size() > 0;
          // Update: aluno corrige a própria contestação OU coord responde (auth)
          allow update: if (request.resource.data.emailAluno == resource.data.emailAluno
                            && request.resource.data.motivo is string)
                           || isAuth();
          allow delete: if isAuth();
        }
      }
    }

    match /fontesRecurso/{fId} {
      allow read: if true;
      allow create, update: if isAuth()
                            && request.resource.data.nome is string
                            && request.resource.data.nome.size() > 0;
      allow delete: if isAuth();
    }

    match /recursosConfig/{cfgId} {
      allow read: if true;
      allow create, update: if isAuth();
      allow delete: if false;
    }

    // ────────────────────────────────────────────────────────────────────────
    // PROJEÇÃO AO VIVO — prof e aluno interagem (modo prof/aluno via URL).
    // Mantém escrita aberta porque aluno desenha strokes em modo remoto.
    // Refatorar quando virar feature mais formal.
    // ────────────────────────────────────────────────────────────────────────
    match /projecaoLive/{liveId} {
      allow read: if true;
      allow create, update: if request.resource.data.simId is string
                            && request.resource.data.alunoId is string;
      allow delete: if true;
      match /strokes/{strokeId} {
        allow read: if true;
        allow create, update: if true;
        allow delete: if true;
      }
      // Streaming em tempo real do traço em andamento (prof desenhando agora).
      // Mesmas regras dos strokes finais — coleção temporária, doc apagado no pointerup.
      match /currentStrokes/{strokeId} {
        allow read: if true;
        allow create, update: if true;
        allow delete: if true;
      }
    }

    // ────────────────────────────────────────────────────────────────────────
    // COMUNICAÇÃO — mural editado por coord. Exige auth.
    // ────────────────────────────────────────────────────────────────────────
    match /comunicacao/{cat} {
      allow read: if true;
      allow create, update: if isAuth();
      allow delete: if false;

      match /posts/{postId} {
        allow read: if true;
        allow create, update: if isAuth()
                              && request.resource.data.titulo is string
                              && request.resource.data.titulo.size() > 0
                              && request.resource.data.titulo.size() < 300
                              && request.resource.data.corpo is string;
        allow delete: if isAuth();
      }
    }

    // ────────────────────────────────────────────────────────────────────────
    // PRODUTOS — Catálogo Interno (marketing/vendas/suporte).
    // Read aberto pra compat com login custom legado (igual a outras coleções
    // do AROS). Alunos não acessam a aba na UI; risco é só leitura direta via
    // SDK por quem souber explorar — aceitável dado o padrão atual do projeto.
    // Write exige auth (Firebase Auth real). Permissão granular `gerenciarCatalogo`
    // é gateada na UI; rules não distinguem permissões dentro de coord/prof.
    // ────────────────────────────────────────────────────────────────────────
    match /produtos/{produtoId} {
      allow read: if isAuth();  // blindado: catálogo interno só logado
      allow create, update: if isAuth()
                            && request.resource.data.nome is string
                            && request.resource.data.nome.size() > 0
                            && request.resource.data.nome.size() < 300
                            && request.resource.data.status in ['rascunho','ativo','aguardando-descricao','em-breve','descontinuado'];
      allow delete: if isAuth();
    }

    // ────────────────────────────────────────────────────────────────────────
    // LIVROS — compilações de apostilas em capítulos (derivadas do PO).
    // ────────────────────────────────────────────────────────────────────────
    match /livros/{livroId} {
      allow read: if isAuth();
      allow create, update: if isAuth()
                            && request.resource.data.nome is string
                            && request.resource.data.nome.size() > 0
                            && request.resource.data.nome.size() < 300;
      allow delete: if isAuth();
    }

    // ────────────────────────────────────────────────────────────────────────
    // AUDIT LOG — append-only. Read aberto pra admin ler. Create aberto pra
    // capturar ações de quem ainda usa login custom (sem Firebase Auth).
    // Update/delete bloqueados — log é imutável.
    // ⚠️  Reads abertos: refatorar pra exigir auth quando aposentar custom login.
    // ────────────────────────────────────────────────────────────────────────
    match /auditLog/{logId} {
      allow read: if isAuth();  // blindado: log só admin logado (create segue aberto p/ legado)
      allow create: if request.resource.data.action is string
                    && request.resource.data.action.size() > 0
                    && request.resource.data.action.size() < 80;
      allow update, delete: if false;
    }

    // ────────────────────────────────────────────────────────────────────────
    // ADMIN UIDS — lista de Firebase Auth UIDs com privilégio admin.
    // Read: aberto pra próprio UID poder se checar via SDK (não vaza nada útil
    // de PII porque o doc só tem email+timestamp).
    // Write: apenas outro admin pode adicionar/remover.
    // ────────────────────────────────────────────────────────────────────────
    match /adminUids/{uid} {
      allow read: if isAuth();  // blindado: checagem do próprio UID só pós-login
      // Bootstrap único do primeiro admin (dono do projeto). UID hardcoded
      // pra evitar que qualquer Firebase Auth user vire admin sozinho.
      // Após o primeiro doc existir, só admin existente pode adicionar outros.
      allow create: if isAuth()
                    && request.auth.uid == uid
                    && uid == 'nF4lKfJXOyPyx6btGkV7Lj0DkQr1';
      allow create, update, delete: if isAdmin();
    }

    // ────────────────────────────────────────────────────────────────────────
    // CRUZAR LISTA — base de alunos da Hotmart, provas e resultados de
    // cruzamento. alunosAprovados contém PII (CPF, email, telefone) → ADMIN ONLY.
    // provas + resultados (sem PII) liberam leitura pra qualquer auth — usado
    // pela box "Aprovações" no catálogo (coord/marketing/vendas leem). Write
    // continua restrito a admin.
    // ────────────────────────────────────────────────────────────────────────
    match /alunosAprovados/{c}     { allow read, write: if isAdmin(); }
    match /provasAprovados/{p}     { allow read: if isAuth(); allow write: if isAdmin(); }
    match /resultadosAprovados/{r} { allow read: if isAuth(); allow write: if isAdmin(); }

    // ────────────────────────────────────────────────────────────────────────
    // PO MEDREVIEW — Coordenação de Produto (gestão interna das aulas).
    // Tudo exige login (dados internos de produção). Importação do Monday roda
    // no app, gravando com a sessão logada do admin (Google/Email).
    // ────────────────────────────────────────────────────────────────────────
    match /poAulas/{aulaId} {
      allow read: if isAuth();
      allow create, update, delete: if isAuth();
    }
    match /poModQuestoes/{key} {
      allow read: if isAuth();
      allow create, update, delete: if isAuth();
    }
    // Transcrições das aulas (texto grande, carregado sob demanda; doc id = vimeoId).
    // Gravadas só pela Cloud Function vimeoTranscricao (Admin SDK ignora rules); cliente só lê.
    match /poTranscricoes/{vimeoId} {
      allow read: if isAuth();
      allow write: if false;
    }
    // Threads de "Erro detectado" e "Dúvidas" por aula (fórum interno do PO).
    match /poErros/{aulaId}   { allow read: if isAuth(); allow create, update, delete: if isAuth(); }
    match /poDuvidas/{aulaId} { allow read: if isAuth(); allow create, update, delete: if isAuth(); }
    // Flashcards por aula: Resumo LM (colado), rascunho gerado pela IA e deck curado.
    // Cliente lê/escreve (curadoria); a Cloud Function gerarFlashcardsPO grava via Admin SDK.
    match /poFlashcards/{aulaId} { allow read: if isAuth(); allow create, update, delete: if isAuth(); }

    // ────────────────────────────────────────────────────────────────────────
    // DEFAULT DENY — qualquer coleção/path não listada acima é bloqueada.
    // ────────────────────────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
