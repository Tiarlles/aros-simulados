rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ────────────────────────────────────────────────────────────────────────
    // REVISÃO DE CASOS — imagens em enunciados, perguntas e obs do item
    // Paths aceitos (profundidade variável):
    //   revisaoCasos/{revId}/{casoId}/{filename}
    //   revisaoCasos/{revId}/{casoId}/obs_{itemId}/{filename}
    // Limite: 15MB por arquivo, apenas imagens (inclui GIFs animados).
    // ────────────────────────────────────────────────────────────────────────
    match /revisaoCasos/{revId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.resource.size < 15 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
      allow delete: if true;
    }

    // ────────────────────────────────────────────────────────────────────────
    // CHECKLIST TEMPLATE — imagens na observação do item (editor direto)
    // Path: checklists/{simId}/obs_imgs/{bloco}/{filename}
    // Mesmas regras da revisão.
    // ────────────────────────────────────────────────────────────────────────
    match /checklists/{simId}/obs_imgs/{allPaths=**} {
      allow read: if true;
      allow write: if request.resource.size < 15 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
      allow delete: if true;
    }

    // ────────────────────────────────────────────────────────────────────────
    // CHECKLIST TEMPLATE — imagens no enunciado do caso e em perguntas (editor
    // direto, usado especialmente em Simulado Extra que não passa por Revisão).
    // Paths aceitos:
    //   checklists/{simId}/tpl_imgs/{bloco}/enun_{ci}/{filename}
    //   checklists/{simId}/tpl_imgs/{bloco}/perg_{ci}_{pi}/{filename}
    // ────────────────────────────────────────────────────────────────────────
    match /checklists/{simId}/tpl_imgs/{allPaths=**} {
      allow read: if true;
      allow write: if request.resource.size < 15 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
      allow delete: if true;
    }

    // ────────────────────────────────────────────────────────────────────────
    // SLIDES DE PROJEÇÃO — imagens/GIFs dos slides aplicados no simulado oral.
    // Path: simulados/{simId}/slides/{casoId}/{idx}_{filename}
    // 15MB pra acomodar GIFs animados.
    // ────────────────────────────────────────────────────────────────────────
    match /simulados/{simId}/slides/{allPaths=**} {
      allow read: if true;
      allow write: if request.resource.size < 15 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
      allow delete: if true;
    }

    // ────────────────────────────────────────────────────────────────────────
    // RECURSOS DE PROVA — imagens anexadas a questões (admin), contestações
    // (aluno) e pareceres (prof).
    // Paths aceitos:
    //   provas/{provaId}/questoes/{qId}/{filename}                 — imagem da questão
    //   provas/{provaId}/questoes/{qId}/contestacoes/{cId}/{file} — anexo do aluno
    //   provas/{provaId}/questoes/{qId}/parecer/{filename}        — anexo do prof
    // 15MB, apenas imagens.
    // ────────────────────────────────────────────────────────────────────────
    match /provas/{provaId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.resource.size < 15 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
      allow delete: if true;
    }

    // ────────────────────────────────────────────────────────────────────────
    // COMUNICAÇÃO — capas dos cards da Home + imagens dos posts do mural.
    // Paths aceitos:
    //   comunicacao/cards/{cat}/{filename}        — capa do card da Home
    //   comunicacao/posts/{cat}/{filename}        — imagem de aviso/post
    // 15MB, apenas imagens.
    // ────────────────────────────────────────────────────────────────────────
    match /comunicacao/{allPaths=**} {
      allow read: if true;
      allow write: if request.resource.size < 15 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
      allow delete: if true;
    }

    // ────────────────────────────────────────────────────────────────────────
    // ORÇAMENTO — anexos dos gastos (notas fiscais, recibos, comprovantes).
    // Path: orcamentos/{eventoId}/gastos/{gastoId}/{filename}
    // Aceita PDF + imagens. 20MB pra acomodar PDFs maiores.
    // ────────────────────────────────────────────────────────────────────────
    match /orcamentos/{eventoId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.resource.size < 20 * 1024 * 1024
                   && (request.resource.contentType.matches('image/.*')
                       || request.resource.contentType == 'application/pdf');
      allow delete: if true;
    }

    // ────────────────────────────────────────────────────────────────────────
    // PRODUTOS — Catálogo interno. Capa + anexos + PDF por feature.
    // Paths aceitos:
    //   produtos/{produtoId}/capa.{ext}                        — capa (img)
    //   produtos/{produtoId}/anexos/{anexoId}.{ext}            — anexos (PDF ou img)
    //   produtos/{produtoId}/features/{featId}/pdf-{ts}.pdf    — PDF anexo por feature
    // Limite: 20MB pra acomodar PDFs grandes (ementa, material didático,
    // apostilas digitalizadas com imagens).
    // Gating de tipo (capa só img) é feito na UI; aqui só barramos por
    // contentType (image/* ou pdf).
    // Read e write exigem auth — alunos não veem este catálogo.
    // ────────────────────────────────────────────────────────────────────────
    match /produtos/{produtoId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 20 * 1024 * 1024
                   && (request.resource.contentType.matches('image/.*')
                       || request.resource.contentType == 'application/pdf');
      allow delete: if request.auth != null;
    }

    // ────────────────────────────────────────────────────────────────────────
    // GROUP REMEMBER — imagens inline no enunciado e perguntas dos casos.
    // Path: remembers/{caseId}/{filename}. 15MB, apenas imagens.
    // ────────────────────────────────────────────────────────────────────────
    match /remembers/{caseId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.resource.size < 15 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
      allow delete: if true;
    }

    // ────────────────────────────────────────────────────────────────────────
    // DEX — PDFs anexados por perfil (referência adicional pra IA)
    // Read pelo Claude API acontece via URL assinada (bypassa rules).
    // Upload/delete exige auth.
    // ────────────────────────────────────────────────────────────────────────
    match /dex/pdfs/{perfil}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 32 * 1024 * 1024
                   && request.resource.contentType == 'application/pdf';
      allow delete: if request.auth != null;
    }

    // ────────────────────────────────────────────────────────────────────────
    // DEFAULT DENY
    // ────────────────────────────────────────────────────────────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
